# Sanity Configuration
# Get these from your Sanity project dashboard (manage.sanity.io)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
# API token for write operations (seed script, contact form submissions)
# Get from sanity.io -> API -> Tokens
SANITY_API_TOKEN=your-write-token
# Optional: Read-only token for public queries
# NEXT_PUBLIC_SANITY_API_TOKEN=your-read-token